# LPM routing: 10.0.0.0/24 → port 1, 10.0.0.0/8 → port 2
add ingress.ipv4_lpm ingress.forward(port:1) hdr.ipv4.dstAddr:0x0A000000/24
add ingress.ipv4_lpm ingress.forward(port:2) hdr.ipv4.dstAddr:0x0A000000/8

# Packet to 10.0.0.1 matches /24 (longest prefix) → port 1, TTL 64→63
packet 0 000000000001 000000000002 0800 45000014 00000000 40060000 0A000001 0A000001
expect 1 000000000001 000000000002 0800 45000014 00000000 3F060000 0A000001 0A000001

# Packet to 10.1.0.1 matches /8 only → port 2, TTL 64→63
packet 0 000000000001 000000000002 0800 45000014 00000000 40060000 0A000001 0A010001
expect 2 000000000001 000000000002 0800 45000014 00000000 3F060000 0A000001 0A010001
